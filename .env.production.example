# Variables d'environnement pour le déploiement en production (VPS)
# Copiez ce fichier en .env et remplissez les valeurs

# Backend
APP_MODE=production
PORT=5000
DB_PATH=data/inventory.db

# CORS — ajoutez votre domaine ici
# Exemple : https://crm.mondomaine.com
CORS_ORIGINS=https://votre-domaine.com,http://frontend:3000

# OpenAI (commandes vocales + analyse IA)
OPENAI_API_KEY=

# OpenRouter (analyse d'étiquettes IA)
OPENROUTER_API_KEY=
